{
  "$schema": "https://json.schemastore.org/package",
  "name": "rna",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish && git push --follow-tags",
    "doc:build": "node scripts/build-docs.mjs"
  },
  "keywords": [
    "design system",
    "vue",
    "eslint",
    "storybook"
  ],
  "author": "H-DNA",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "overrides": {
      "@vitest/browser": "^4.1.6",
      "minimatch@>=10.0.0": "^10.2.5",
      "minimatch@<3.1.3": "^3.1.3",
      "lodash@>=4.0.0": "^4.18.0",
      "esbuild@>=0.17.0": "^0.28.1",
      "ajv@>=7.0.0": "^8.18.0"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@hdnax/nuclint": "workspace:*",
    "eslint": "^10.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.2.8"
  }
}

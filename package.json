{
  "$schema": "https://json.schemastore.org/package",
  "name": "rna",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish && git push --follow-tags",
    "doc:build": "node scripts/build-docs.mjs"
  },
  "keywords": [
    "design system",
    "vue",
    "eslint",
    "storybook"
  ],
  "author": "H-DNA",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "overrides": {
      "@vitest/browser": "^4.1.6"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@hdnax/nuclint": "workspace:*",
    "eslint": "^10.3.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.8"
  }
}

{
  "$schema": "https://json.schemastore.org/package",
  "name": "@hdnax/genuix",
  "version": "0.5.0",
  "description": "A personal design system - Gene + UI/UX = Genuix.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hdnax/rna.git",
    "directory": "packages/genuix"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/genuix.js",
      "require": "./dist/genuix.umd.cjs"
    },
    "./style.css": "./dist/genuix.css"
  },
  "main": "./dist/genuix.umd.cjs",
  "module": "./dist/genuix.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "design system",
    "vue",
    "storybook"
  ],
  "scripts": {
    "dev": "storybook dev -p 8686",
    "build": "vite build",
    "build-storybook": "storybook build",
    "doc:build": "storybook build -o doc-dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@hdnax/stdx": "workspace:*",
    "dompurify": "^3.4.0",
    "floating-vue": "^5.2.2",
    "luxon": "^3.7.2"
  },
  "peerDependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "highlight.js": "^11.0.0",
    "vue": "^3.5.26"
  },
  "devDependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@hdnax/nuclint": "workspace:*",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-vitest": "10.3.5",
    "@storybook/vue3-vite": "10.3.5",
    "@tailwindcss/vite": "^4.1.18",
    "@types/luxon": "^3.7.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.4",
    "highlight.js": "^11.0.0",
    "storybook": "10.3.5",
    "storybook-addon-vue-slots": "^0.9.29",
    "storybook-design-token": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}

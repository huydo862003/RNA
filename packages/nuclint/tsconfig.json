{
  "extends": "../../tsconfig.base.json",
  "include": [
    "*.ts",
    "src/**/*.ts",
    "__tests__/**/*.ts"
  ],
  "compilerOptions": {
    "rootDir": "./",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@tests/*": [
        "./__tests__/*"
      ]
    },
    "ignoreDeprecations": "6.0"
  }
}

{
  "$schema": "https://json.schemastore.org/package",
  "name": "@hdnax/nuclint",
  "version": "0.16.0",
  "description": "Shared ESLint configuration.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hdnax/rna.git",
    "directory": "packages/nuclint"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "eslint"
  ],
  "scripts": {
    "build": "tsup --tsconfig ./tsconfig.build.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint ./src ./eslint.config.ts --fix",
    "prepublishOnly": "mv ./README.md ./README.md.backup && mv ./README.npm.md ./README.md && pnpm run build",
    "postpublish": "mv ./README.md ./README.npm.md && mv ./README.md.backup ./README.md"
  },
  "peerDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-vue": "^10.9.1",
    "typescript-eslint": "^8.59.2",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.6.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0"
  }
}
